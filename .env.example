# LLM API Keys (至少填一个)
GEMINI_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# 飞书应用配置 (必填)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 数据源 (Finnhub 免费 Key，建议注册: https://finnhub.io)
FINNHUB_API_KEY=

# 默认 LLM 模型标识
# 可选: gemini/gemini-2.0-flash, gpt-4o, dashscope/qwen-plus
DEFAULT_LLM=gemini/gemini-2.0-flash

# 图表临时文件目录
CHARTS_DIR=./charts

# 富途 OpenD 只读数据源（默认关闭；true 时前端 /futu 菜单可见）
FUTU_ENABLED=false
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_TRD_ENV=SIMULATE       # SIMULATE / REAL（仅查询，代码层禁止下单）
FUTU_TRD_MARKET=US          # US / HK / CN

# ───── 账号体系（必填） ─────
# JWT 密钥：生产环境请用 `openssl rand -hex 32` 生成，不要提交真实值
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# 首个管理员：首次启动时 users 表为空会自动播种，之后不再读取
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-strong-password
