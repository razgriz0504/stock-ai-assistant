# LLM API Keys (至少填一个)
GEMINI_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# 飞书应用配置 (必填)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 数据源 (Finnhub 免费 Key，建议注册: https://finnhub.io)
FINNHUB_API_KEY=

# 默认 LLM 模型标识
# 可选: gemini/gemini-2.0-flash, gpt-4o, dashscope/qwen-plus
DEFAULT_LLM=gemini/gemini-2.0-flash

# 图表临时文件目录
CHARTS_DIR=./charts
